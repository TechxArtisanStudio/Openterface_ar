---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { docsPath } from '../../config/site';
---

<BaseLayout
  title="عن Openterface"
  description="تعرّف على Openterface — حلول KVM-over-USB مفتوحة المصدر من TechxArtisan."
  ogImageAlt="حلول Openterface KVM-over-USB مفتوحة المصدر من TechxArtisan"
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">عن Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        تطوّر Openterface أدوات KVM-over-USB مفتوحة المصدر فائقة الصغر لمحترفي IT والمطورين وصناع المحتوى.
        من Mini-KVM الذي جمع التمويل الجماعي إلى KVM-GO بحجم مفتاح وسلسلة KeyMod القابلة للبرمجة — مهمتنا تبسيط التحكم في أجهزة headless دون معدات ضخمة أو شبكات معقدة.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={docsPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          المزيد عنا →
        </a>
        <a href={docsPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          الامتثال →
        </a>
        <a href={docsPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          المجتمع →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
